{
  "name": "ssh-sync",
  "version": "0.5.0",
  "description": "Sync selected vaults with a remote server via SSH using rsync.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -noEmit -skipLibCheck",
    "eslint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@typescript-eslint/parser": "^8.59.2",
    "esbuild": "0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "obsidian": "latest",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
